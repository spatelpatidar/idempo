# frozen_string_literal: true

# Idempo — Idempotency for Rails APIs, Jobs, and Webhooks
# App    : <%= @app_name %>
# Generated by `rails generate idempo:install`
# Docs   : https://github.com/your-org/idempo

Idempo.configure do |config|
  # ── Expiry ─────────────────────────────────────────────────────────────────
  # How long idempotency records are retained before cleanup.
  # Run `rake idempo:cleanup` (or schedule it) to purge expired records.
  config.expiry = <%= @expiry_value %>

  # ── Payload enforcement ────────────────────────────────────────────────────
  # true  → reusing a key with a different body raises PayloadMismatchError (409)
  # false → mismatch is logged; cached response is returned silently
  config.enforce_payload_match = <%= @enforce_match %>

  # ── Response replay ────────────────────────────────────────────────────────
  # true  → duplicate requests receive the exact original HTTP status + JSON body
  # false → duplicate requests are blocked (409, no body)
  config.store_response = <%= @store_response %>

  # ── Storage backend ────────────────────────────────────────────────────────
<% if @storage_backend == "redis" %>
  # Redis — sub-millisecond lookups, built-in TTL (no cleanup job needed).
  # Requires: gem "redis" in your Gemfile.
  config.redis = Redis.new(url: ENV.fetch("REDIS_URL", "redis://localhost:6379"))
  config.store = Idempo::Storage::Redis.new
<% else %>
  # ActiveRecord — uses your existing database, no extra infrastructure needed.
  config.store = Idempo::Storage::ActiveRecord.new
<% end %>

  # ── Non-cacheable HTTP statuses ────────────────────────────────────────────
  # Responses with these codes are NOT stored — clients may safely retry them.
  config.non_cacheable_statuses = (500..599).to_a

  # ── Key length limit ───────────────────────────────────────────────────────
  config.max_key_length = 255

  # ── Logger ─────────────────────────────────────────────────────────────────
  # Defaults to Rails.logger. Produces [Idempo] HIT / MISS / LOCKED lines.
  # To silence: config.logger = Logger.new(nil)
  # config.logger = Rails.logger
end
