# frozen_string_literal: true

# Idempo — Idempotency for Rails APIs, Jobs, and Webhooks
# Generated by `rails generate idempo:install`
#
# See https://github.com/your-org/idempo for full documentation.

Idempo.configure do |config|
  # How long idempotency records are retained.
  # After this period, records are eligible for cleanup via Idempo.cleanup_expired!
  # or the `rake idempo:cleanup` task.
  config.expiry = 24.hours

  # When true (default), reusing the same key with a different request payload
  # raises Idempo::PayloadMismatchError and returns HTTP 409.
  # Set to false to silently return the cached response instead.
  config.enforce_payload_match = true

  # When true (default), successful responses are stored and replayed verbatim
  # for duplicate requests. Set to false to only deduplicate (no replay).
  config.store_response = true

  # HTTP status codes that should NOT be cached. Requests that result in these
  # statuses can be retried freely (the idempotency record is released).
  config.non_cacheable_statuses = (500..599).to_a

  # Maximum allowed length for an idempotency key string.
  config.max_key_length = 255

  # Backing store. Defaults to the ActiveRecord store (requires migration).
  # config.store = Idempo::Storage::ActiveRecord.new

  # Optional: Redis client for distributed locking.
  # Uncomment and configure if you want Redis-backed locking.
  # config.redis = Redis.new(url: ENV.fetch("REDIS_URL", "redis://localhost:6379"))

  # Logger. Defaults to Rails.logger.
  # config.logger = Rails.logger
end
